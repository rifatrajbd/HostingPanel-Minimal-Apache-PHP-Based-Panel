#!/usr/bin/env php
<?php

/**
 * panelctl — privileged operations CLI for HostingPanel.
 *
 * Used directly by root over SSH, by root cron jobs (cf:update, backups),
 * and as the dev-mode bridge (--dry-run) for the panel UI. In production
 * the panel talks to the panelctld daemon over a socket instead — but the
 * exact same command classes back both paths (see src/bootstrap.php).
 *
 * Secrets are read from STDIN, never from argv.
 *
 *   panelctl site:create --domain example.com --php 8.1
 *   panelctl db:create   --name mydb --user myuser        (password on stdin)
 *   panelctl mail:mailbox:add --address me@example.com    (password on stdin)
 *
 * Add --dry-run to print actions without executing.
 */

declare(strict_types=1);

require __DIR__ . '/src/bootstrap.php';

$args = array_slice($argv, 1);
$command = null;
$flags = [];
$dryRun = false;

for ($i = 0; $i < count($args); $i++) {
    $arg = $args[$i];
    if ($arg === '--dry-run') {
        $dryRun = true;
    } elseif (str_starts_with($arg, '--')) {
        $name = substr($arg, 2);
        $value = $args[$i + 1] ?? '';
        if (str_starts_with($value, '--')) {
            $value = '1'; // bare flag
        } else {
            $i++;
        }
        $flags[$name] = $value;
    } elseif ($command === null) {
        $command = $arg;
    }
}

if ($command === null || !isset(Dispatcher::map()[$command])) {
    fwrite(STDERR, "Usage: panelctl <command> [--flag value …]\nCommands:\n  "
        . implode("\n  ", array_keys(Dispatcher::map())) . "\n");
    exit(2);
}

if (!$dryRun && function_exists('posix_geteuid') && posix_geteuid() !== 0) {
    fwrite(STDERR, "panelctl must run as root.\n");
    exit(3);
}

// Secret / payload comes in on STDIN for the CLI.
$stdin = '';
if (!$dryRun && defined('STDIN') && !stream_isatty(STDIN)) {
    $stdin = (string) stream_get_contents(STDIN);
}

[$code, $stdout, $stderr] = Dispatcher::dispatch($command, $flags, $stdin, $dryRun);

if ($stdout !== '') {
    fwrite(STDOUT, $stdout);
}
if ($stderr !== '') {
    fwrite(STDERR, 'Error: ' . $stderr . "\n");
}
exit($code);

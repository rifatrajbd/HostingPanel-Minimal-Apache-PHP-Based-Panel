# /etc/fail2ban/jail.d/hostingpanel.local
[DEFAULT]
bantime = 1h
findtime = 15m
maxretry = 5

[sshd]
enabled = true

[postfix]
enabled = true
mode = aggressive

[dovecot]
enabled = true

[apache-auth]
enabled = true

[apache-badbots]
enabled = true

# Brute-force protection for the HostingPanel login itself.
[hostingpanel-panel]
enabled  = true
filter   = hostingpanel
logpath  = /var/log/hostingpanel/auth.log
port     = 8443
maxretry = 5
findtime = 15m
bantime  = 1h

{
  "permissions": {
    "allow": [
      "Bash(php -v)",
      "Bash(npm -v)",
      "Bash(php panel/composer.phar --version)",
      "Bash(php -m)",
      "Bash(grep -iE \"^\\(pdo_sqlite|mbstring|openssl|tokenizer|xml|ctype|json|bcmath|fileinfo|curl|zip|gd\\)$\")",
      "Bash(curl -fsS --connect-timeout 10 -o /dev/null -w \"%{http_code}\" https://repo.packagist.org/packages.json)",
      "Bash(php artisan *)",
      "WebSearch",
      "WebFetch(domain:docs.directadmin.com)",
      "Bash(php -l panelctl/src/FsCommands.php)",
      "Bash(php -r 'require \"panelctl/src/bootstrap.php\"; echo \"commands: \".count\\(Dispatcher::map\\(\\)\\).\"\\\\n\";')",
      "Bash(php panelctl/panelctl fs:search --domain forum.example.com --query conf --dry-run)",
      "Bash(php panelctl/panelctl fs:list --domain forum.example.com --path / --sizes 1 --dry-run)"
    ]
  }
}
